{
  "name": "@codesift/core",
  "version": "0.0.0",
  "description": "Core engine and SDK for codesift.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": "^20.0.0 || ^22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "ignore": "^7.0.5",
    "minimatch": "^10.1.1",
    "sqlite-vec": "^0.1.9",
    "typescript": "^5.9.3"
  }
}
