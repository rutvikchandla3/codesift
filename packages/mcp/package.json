{
  "name": "@codesift/mcp",
  "version": "0.0.0",
  "description": "MCP server package for codesift.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": "^20.0.0 || ^22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codesift/core": "workspace:*"
  }
}
